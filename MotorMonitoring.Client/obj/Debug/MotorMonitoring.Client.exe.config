<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<appSettings>
		<add key="csvPath" value="C:\Users\Korisnik\Desktop\virtuelizacija_projekat\MotorMonitoring\Data\measures_v2.csv"/>
		<add key="logPath" value="C:\Users\Korisnik\Desktop\virtuelizacija_projekat\MotorMonitoring\Data\rejects.log"/>
	</appSettings>
	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<binding name="motorBinding"
						 maxReceivedMessageSize="10485760"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:05:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"/>
			</netTcpBinding>
		</bindings>
		<client>
			<endpoint
			  name="MotorService"
			  address="net.tcp://localhost:8000/MotorService"
			  binding="netTcpBinding"
			  bindingConfiguration="motorBinding"
			  contract="MotorMonitoring.Contracts.IMotorService"/>
		</client>
	</system.serviceModel>
</configuration>