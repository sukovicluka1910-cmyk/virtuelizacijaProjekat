<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<appSettings>
		<add key="Id_threshold" value="0.5"/>
		<add key="Iq_threshold" value="0.5"/>
		<add key="T_threshold" value="2.0"/>
		<add key="storagePath" value="C:\Users\Korisnik\Desktop\virtuelizacija_projekat\MotorMonitoring\Data\"/>
	</appSettings>
	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<binding name="motorBinding"
						 maxReceivedMessageSize="10485760"
						 sendTimeout="00:05:00"
						 receiveTimeout="00:05:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"/>
			</netTcpBinding>
		</bindings>
		<services>
			<service name="MotorMonitoring.Service.MotorService">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:8000"/>
					</baseAddresses>
				</host>
				<endpoint
				  address="MotorService"
				  binding="netTcpBinding"
				  bindingConfiguration="motorBinding"
				  contract="MotorMonitoring.Contracts.IMotorService"/>
			</service>
		</services>
	</system.serviceModel>
</configuration>